# Copy to .env and fill in values. Never commit .env.

# Required
GEMINI_API_KEY=YOUR_KEY_HERE

# Serper.dev API key (serper.dev — 2500 free queries/month)
SERPER_API_KEY=YOUR_KEY_HERE

# Sender identity in the email signature
# SENDER_NAME=Alex
# SENDER_ROLE=Kyber Knight Capital

# Model override (default: gemini-flash-latest)
# GEMINI_MODEL=gemini-flash-latest

# Fetch cache — speeds up reruns on the same contacts (off by default)
# FETCH_CACHE_ENABLED=1
